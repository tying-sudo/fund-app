{
  "name": "fund-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node dev-server.mjs",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "vite build",
    "test:holding": "node --experimental-strip-types scripts/verify-holding-settlement.mjs",
    "preview": "vite preview",
    "update-funds": "node scripts/fetch-fund-list.mjs",
    "cap:init": "npx cap init",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android"
  },
  "dependencies": {
    "@capacitor/android": "^7.4.5",
    "@capacitor/app": "^7.1.1",
    "@capacitor/core": "^7.0.0",
    "@vant/use": "^1.6.0",
    "lightweight-charts": "^5.1.0",
    "pinia": "^3.0.0",
    "tesseract.js": "^7.0.0",
    "vant": "^4.9.0",
    "vue": "^3.5.24",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "@types/node": "^24.10.1",
    "@vant/auto-import-resolver": "^1.2.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^4.22.2",
    "node-cron": "^3.0.3",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^19.0.0",
    "unplugin-vue-components": "^28.0.0",
    "vite": "^7.2.4",
    "vue-tsc": "^3.1.4"
  }
}
